# Copy this file to .env and fill in real local values before running podman-compose.
# Do not commit podman/.env.

# Discord bot token from the Discord developer portal.
DISCORD_TOKEN=replace-with-discord-bot-token

# VolumeLeaders credentials consumed by rusty-volumeleaders.
VL_USERNAME=replace-with-volumeleaders-username
VL_PASSWORD=replace-with-volumeleaders-password
